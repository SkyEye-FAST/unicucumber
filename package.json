    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/material-symbols": "^1.2.85",
    "@iconify/vue": "^5.0.1",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/eslint-config-prettier": "^10.2.0",
