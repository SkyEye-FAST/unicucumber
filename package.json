{
  "name": "unicucumber",
  "description": "A project for editing Unifont glyphs in browsers",
  "version": "1.1.0",
  "author": "SkyEye_FAST <skyeyefast@foxmail.com>",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/SkyEye-FAST/unicucumber",
  "readme": "README.md",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.34.5+sha512.a4ee05f2f73658255bd6a89859c065a45c28a57daefae2c893a168ee2b73168c37b91e83e57ea67654ad03f03031746430e8bce38e362e042605fb8abc80192e",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check": "run-p type-check lint format:check test",
    "chunk-unifont": "node scripts/chunk-unifont.js",
    "update-unifont": "node scripts/update-unifont.js"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "buffer": "^6.0.3",
    "iconv-lite": "^0.7.3",
    "stream-browserify": "^3.0.0",
    "unicode-name": "^1.1.0",
    "vue": "^3.5.40",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/material-symbols": "^1.2.85",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@playwright/test": "1.61.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.10.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "fake-indexeddb": "6.2.5",
    "happy-dom": "^20.10.6",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.5",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7",
    "workbox-build": "7.4.1",
    "workbox-window": "7.4.1"
  }
}